# AtlasKernel environment — DO NOT commit this file
APP_ENV=development
APP_NAME=AtlasKernel
LOG_LEVEL=INFO

# Required for LLM calls
OPENROUTER_API_KEY=

# LLM backend selection (local | gemini | openrouter | fallback)
# Overrides automatic task-type routing when set
LLM_BACKEND=

# Local Ollama backend (used when LLM_BACKEND=local or task type matches code/debug)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=codellama

# Optional overrides
# CONFIG_PATH=config/model_router.json
# LOGS_DIR=logs
